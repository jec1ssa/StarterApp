<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="StarterApp.Views.ItemDetailPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">

            <Label Text="{Binding Item.Title}"
                   FontSize="28"
                   FontAttributes="Bold" />

            <Label Text="{Binding Item.Description}"
                   FontSize="16" />

            <Label Text="{Binding Item.Category, StringFormat='Category: {0}'}" />

            <Label Text="{Binding Item.OwnerName, StringFormat='Owner: {0}'}" />

            <Label Text="{Binding Item.DailyRate, StringFormat='£{0:F2} per day'}"
                   FontSize="20"
                   FontAttributes="Bold" />

            <Label Text="{Binding Item.AverageRating, StringFormat='Average rating: {0:F1} stars'}" />

            <Label Text="{Binding Item.TotalReviews, StringFormat='Reviews: {0}'}" />

            <Label Text="{Binding Item.IsAvailable, StringFormat='Available: {0}'}" />

            <Label Text="Edit Listing"
                   FontSize="20"
                   FontAttributes="Bold"
                   Margin="0,20,0,0"
                   IsVisible="{Binding CanEditItem}" />

            <Label Text="Title"
                   IsVisible="{Binding CanEditItem}" />
            <Entry Text="{Binding EditTitle}"
                   IsVisible="{Binding CanEditItem}" />

            <Label Text="Description"
                   IsVisible="{Binding CanEditItem}" />
            <Editor Text="{Binding EditDescription}"
                    AutoSize="TextChanges"
                    HeightRequest="100"
                    IsVisible="{Binding CanEditItem}" />

            <Label Text="Daily Rate"
                   IsVisible="{Binding CanEditItem}" />
            <Entry Text="{Binding EditDailyRate}"
                   Keyboard="Numeric"
                   IsVisible="{Binding CanEditItem}" />

            <HorizontalStackLayout Spacing="10"
                                   IsVisible="{Binding CanEditItem}">
                <Label Text="Available"
                       VerticalOptions="Center" />
                <Switch IsToggled="{Binding EditIsAvailable}" />
            </HorizontalStackLayout>

            <Button Text="Save Item Changes"
                    Command="{Binding SaveItemChangesCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                    IsVisible="{Binding CanEditItem}" />

            <Label Text="Rental Dates"
       FontSize="20"
       FontAttributes="Bold"
       Margin="0,20,0,0" />

<Label Text="Start Date" />
<DatePicker Date="{Binding StartDate}" />

<Label Text="End Date" />
<DatePicker Date="{Binding EndDate}" />

<Border BackgroundColor="#003300"
        Stroke="#4CAF50"
        StrokeThickness="1"
        Padding="10"
        IsVisible="{Binding HasSuccess}">
    <Label Text="{Binding SuccessMessage}"
           TextColor="#4CAF50" />
</Border>

<Button Text="Request Rental"
        Command="{Binding RequestRentalCommand}"
        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
        Margin="0,20,0,0" />


            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red"
                   IsVisible="{Binding HasError}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
