<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StarterApp.Views.ItemsListPage"
             x:Name="ItemsListPageRoot"
             Title="{Binding Title}">


    <Grid Padding="20" RowSpacing="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Label Grid.Row="0"
               Text="Rental Marketplace"
               FontSize="28"
               FontAttributes="Bold" />

        <Grid Grid.Row="1"
      ColumnDefinitions="*,*"
      ColumnSpacing="10">

    <Button Grid.Column="0"
            Text="Refresh"
            Command="{Binding LoadItemsCommand}" />

    <Button Grid.Column="1"
            Text="Add Item"
            Command="{Binding GoToCreateItemCommand}" />
</Grid>


        <Border Grid.Row="2"
                BackgroundColor="#330000"
                Stroke="#EF5350"
                StrokeThickness="1"
                Padding="10"
                IsVisible="{Binding HasError}">
            <Label Text="{Binding ErrorMessage}"
                   TextColor="#EF5350" />
        </Border>

        <CollectionView Grid.Row="3"
                        ItemsSource="{Binding Items}">
            <CollectionView.EmptyView>
                <Label Text="No items found."
                       FontSize="16"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Stroke="#555"
        StrokeThickness="1"
        Padding="15"
        Margin="0,6"
        BackgroundColor="#222">
    <Border.GestureRecognizers>
        <TapGestureRecognizer
            Command="{Binding BindingContext.GoToItemDetailCommand, Source={x:Reference ItemsListPageRoot}}"
            CommandParameter="{Binding .}" />
    </Border.GestureRecognizers>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="{Binding Title}"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="White" />

                            <Label Text="{Binding Description}"
                                   FontSize="14"
                                   TextColor="#CCCCCC"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="2" />

                            <Label Text="{Binding Category, StringFormat='Category: {0}'}"
                                   TextColor="#CCCCCC" />

                            <Label Text="{Binding OwnerName, StringFormat='Owner: {0}'}"
                                   TextColor="#CCCCCC" />

                            <Label Text="{Binding DailyRate, StringFormat='£{0:F2} per day'}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="#B39DDB" />

                            <Label Text="{Binding AverageRating, StringFormat='Rating: {0:F1} stars'}"
                                   TextColor="#CCCCCC" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>